{
    "compilerOptions": {
        "outDir": "bin",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "es2022",
        "lib": ["es2022"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    }
}
